    "vue": "^3.5.32"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/coverage-v8": "^4.1.6",
    "@vue/server-renderer": "^3.5.34",
    "@vue/test-utils": "^2.4.10",
    "jsdom": "^29.1.1",
    "vite": "^8.0.9",
    "vitest": "^4.1.6"
  }
}
